# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# ssh
# export SSH_KEY_PATH="~/.ssh/rsa_id"

# Set personal aliases, overriding those provided by oh-my-bash libs,
# plugins, and themes. Aliases can be placed here, though oh-my-bash
# users are encouraged to define aliases within the OSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias bashconfig="mate ~/.bashrc"
# alias ohmybash="mate ~/.oh-my-bash"

# Custom aliases
alias ls='lsd'
alias ll='lsd -lh'
alias la='lsd -a'
alias l='lsd'
# alias bat='batcat'  # Only needed on Debian/Ubuntu where bat is named batcat

# ble.sh se carga de forma diferida para no retrasar el inicio de la terminal
# (se activa al final del .bashrc)

# 1. Define the logic in a standard Bash function
sudo_toggle_bash() {
    if [[ $READLINE_LINE == sudo\ * ]]; then
        READLINE_LINE="${READLINE_LINE#sudo }"
    else
        READLINE_LINE="sudo $READLINE_LINE"
    fi
    READLINE_POINT=${#READLINE_LINE}
}

# 2. Register the keybinding (compatible with ble.sh)
if [[ ${BLE_VERSION-} ]]; then
    ble/widget/sudo_toggle_bash() {
        local text=${_ble_edit_str}
        if [[ $text == sudo\ * ]]; then
            ble/widget/.replace-range 0 5 ''
        else
            ble/widget/.replace-range 0 0 'sudo '
        fi
    }
    ble-bind -f 'C-s' sudo_toggle_bash
else
    bind -x '"\e\e": sudo_toggle_bash'
fi

# Cargar ble.sh al final del .bashrc (requiere Bash 4.0+)
if [[ -f ~/.local/share/blesh/ble.sh && ${BASH_VERSINFO[0]} -ge 4 ]]; then
    source ~/.local/share/blesh/ble.sh
fi